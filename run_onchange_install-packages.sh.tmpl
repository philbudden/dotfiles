#!/usr/bin/env bash
set -euo pipefail

if ! command -v brew >/dev/null 2>&1; then
  echo "Skipping package install: Homebrew is not available in this environment."
  exit 0
fi

brew_packages=(
{{- range .packages.brew }}
  {{ . | quote }}
{{- end }}
)

gh_extensions=(
{{- range .packages.gh_extensions }}
  {{ . | quote }}
{{- end }}
)

for package in "${brew_packages[@]}"; do
  if brew list --formula "$package" >/dev/null 2>&1; then
    echo "brew package present: $package"
    continue
  fi

  echo "Installing brew package: $package"
  brew install "$package"
done

if ! command -v gh >/dev/null 2>&1; then
  echo "Skipping GitHub CLI extension install: gh is not available yet."
  exit 0
fi

if ! gh auth status >/dev/null 2>&1; then
  echo "Skipping GitHub CLI extension install: provide working GitHub auth via GH_TOKEN, GITHUB_TOKEN, or GH_CONFIG_DIR."
  exit 0
fi

installed_extensions="$(gh extension list 2>/dev/null | awk 'NF { print $1 }')"
for extension in "${gh_extensions[@]}"; do
  if printf '%s\n' "$installed_extensions" | grep -Fxq "$extension"; then
    echo "gh extension present: $extension"
    continue
  fi

  echo "Installing gh extension: $extension"
  gh extension install "$extension"
done
